            "label": "2026-03-24_18-59-36",
            "content": "package main\n\nimport \"fmt\"\n\nfunc main() {\n    var n int\n    fmt.Scan(&n)\n\n    fila := make([]int, n)\n    for i := 0; i < n; i++ {\n        fmt.Scan(&fila[i])\n    }\n\n    var m int\n    fmt.Scan(&m)\n\n    saiu := make([]int, m)\n    for i := 0; i < m; i++ {\n        fmt.Scan(&saiu[i])\n    }\n\n    removidos := make(map[int]bool)\n\n    for i := 0; i < m; i++ {\n        removidos[saiu[i]] = true\n    }\n\n    for i := 0; i < n; i++ {\n        if !removidos[fila[i]] {\n            fmt.Printf(\"%d \", fila[i])\n        }\n    }\n\n    fmt.Println()\n}",
